        G4[Range / shell rows are NOT<br/>lot-level cost]:::guard
        G5[Harmony joins require<br/>project + phase + lot]:::guard
        G6[Decoder rules are inferred,<br/>not source-owner-validated]:::guard
        G7[DataRails raw sums are<br/>unsafe without dedup]:::guard
        G8[QB Register is tie-out only]:::guard
    end

