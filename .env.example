# в”Ђв”Ђв”Ђ Copy this file to `.env` and fill in real values в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# `.env` is gitignored. `.env.example` is tracked so the schema stays visible.

# в”Ђв”Ђ Google Cloud Storage в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Path to a service-account JSON with read access to the GCS bucket below.
# Alternative: leave blank and run `gcloud auth application-default login`,
# which writes Application Default Credentials the SDK will pick up automatically.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional: GCP project. Usually inferred from the service-account JSON,
# only set this if the SDK complains about missing project.
GCP_PROJECT_ID=

# Default bucket for `python3 -m schemas.register_xlsx` (so you can omit --bucket).
GCS_BUCKET=

# Optional default prefix to walk when --prefix is omitted (e.g. "exports/2026-q1/").
GCS_PREFIX=

# в”Ђв”Ђ Anthropic (used by schemas.enrich_descriptions once it's wired up) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ANTHROPIC_API_KEY=

# в”Ђв”Ђ Tool Engine substrate (Phase 1) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Postgres connection. Default values match docker-compose.yml.
POSTGRES_USER=engine
POSTGRES_PASSWORD=engine
POSTGRES_DB=engine
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# The async runtime URL. SQLAlchemy reads this.
DATABASE_URL=postgresql+asyncpg://engine:engine@localhost:5432/engine

# Comma-separated list of active notification channels. `inbox` is always on.
# Phase 2 channels (email, slack) plug in here once their modules exist.
NOTIFICATION_CHANNELS=inbox
