      "data_type": "currency_usd",
      "grain": "phase_x_lot_type",
      "formula": "effective_direct_budget + indirect_allocated + land_allocated + water_allocated + warranty_allocated",
      "compute_status": "computed_when_inputs_present"
    },
    {
      "field_id": "sales_price_per_lot",
      "label": "Sales Price / Lot",
      "category": "input",
      "data_type": "currency_usd",
      "grain": "phase_x_lot_type",
