      "source_eventually": "landdev_api.current_budget WHERE prefix=IND AND community=this.community",
      "required": true,
      "confidence": "high_when_present",
      "compute_status": "input_required"
    },
    {
      "field_id": "indirect_allocated",
      "label": "Indirect Allocated",
      "category": "computed",
      "data_type": "currency_usd",
      "grain": "phase_x_lot_type",
      "formula": "indirect_pool_community * sales_basis_pct_community",
      "method_id_ref": "indirect_community",
      "compute_status": "computed_when_inputs_present",
      "ratified": true,
      "satellite_observation": "PF satellite shows negative indirect pool ($-1,249,493.54). Treat as workbook credit; flag in output."
    },
    {
      "field_id": "water_pool_phase",
      "label": "Water Pool (per phase, from letter)",
      "category": "input",
      "data_type": "currency_usd",
      "grain": "phase",
      "source_today": "indirect_pool entry tagged with water (e.g., 'Ault Water $702,262.00') OR satellite cost-of-water column",
      "source_eventually": "water_letter_per_phase",
      "required": false,
      "required_when": "phase_uses_water_method",
      "confidence": "medium_when_present",
      "compute_status": "input_required_for_water_method"
    },
    {
      "field_id": "water_allocated",
      "label": "Water Allocated",
      "category": "computed",
      "data_type": "currency_usd",
      "grain": "phase_x_lot_type",
      "formula": "water_pool * (phase_units / total_units_in_letter)",
      "method_id_ref": "water_by_letter",
      "compute_status": "computed_when_inputs_present",
      "ratified": true,
      "missing_in_master": true,
      "fix_required": "Add water column to master Flagship Per-Lot Output sheet."
    },
    {
