      "category": "computed",
      "data_type": "currency_usd",
      "grain": "phase_x_lot_type",
      "formula": "land_pool_community * sales_basis_pct_community",
      "method_id_ref": "land_at_mda",
      "trigger_event": "mda_execution",
      "compute_status": "computed_when_inputs_present",
