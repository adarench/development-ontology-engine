      "label": "Direct Budget Estimate (per-lot rule)",
      "category": "input_estimated",
      "data_type": "currency_usd",
      "grain": "phase",
      "source_today": "satellite_comment_field (e.g., 'Est. $60k/lot', 'Est. $45k/lot')",
