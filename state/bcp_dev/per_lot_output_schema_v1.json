      "source_today": "per_lot_output.direct_budget_landdev (master) or satellite Budgeting.Directs.Curr Budget LandDev",
      "source_eventually": "landdev_api.current_budget WHERE prefix=DIR AND phase=this.phase",
      "required": true,
      "confidence": "high_when_present",
      "compute_status": "input_required"
    },
    {
      "field_id": "direct_budget_override",
      "label": "Direct Budget Override",
      "category": "input",
      "data_type": "currency_usd",
      "grain": "phase",
      "source_today": "manual",
      "required": false,
      "confidence": "low",
      "compute_status": "input_optional",
