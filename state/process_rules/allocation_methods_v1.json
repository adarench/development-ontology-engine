  "methods": [
    {
      "rule_id": "ALLOC-001",
      "method_id": "land_at_mda",
      "name": "Land Allocation at MDA Execution",
      "applies_to": {
        "cost_type": "Land",
        "scope": "phase",
        "posting_account": "131-200",
        "alloc_pair": "131-100→131-200 (initial), 131-200→131-300 (at pre-con), 131-300→131-010 (at lot sale)"
      },
      "trigger_event": "mda_execution",
      "trigger_event_secondary": ["pre_con", "lot_sale"],
      "inputs_required": [
        {"input": "raw_land_basis_per_property", "system": "qbd_131-100", "type": "currency_usd"},
        {"input": "lot_count_at_mda", "system": "mda_doc", "type": "int"},
        {"input": "lot_count_in_phase", "system": "clickup_phase_task", "type": "int"},
        {"input": "lot_count_total_property", "system": "clickup_aggregate_or_workbook", "type": "int"},
        {"input": "lot_type_mix", "system": "clickup", "type": "dict[lot_type→int]"}
      ],
      "calculation": {
        "phase_share_usd": "raw_land_basis_per_property * (lot_count_in_phase / lot_count_total_property)",
        "per_lot_share_usd": "phase_share_usd / lot_count_in_phase",
        "weighting_note": "Briefing describes lot-count weighting. If lot-type weighting (SFR vs TH vs MF basis differential) is later required, it lives in a v2 method, not here."
      },
      "hard_gates": ["mda_day_lot_count_check"],
      "ratified": true,
      "verification_status": "source_doc_extracted",
      "verification_note": "Confirmed in briefing as the canonical land allocation pattern."
    },
    {
      "rule_id": "ALLOC-002",
      "method_id": "water_by_letter",
      "name": "Water Allocation per Water Requirement Letter",
      "applies_to": {
        "cost_type": "Water",
        "scope": "phase",
        "posting_account": "132-700",
        "alloc_pair": "132-700↔132-710"
      },
      "trigger_event": "water_letter_received",
      "trigger_event_secondary": ["pre_con", "lot_sale"],
      "inputs_required": [
        {"input": "water_letter_units_phase", "system": "water_letter", "type": "int_or_decimal"},
        {"input": "water_letter_units_total", "system": "water_letter_or_workbook", "type": "int_or_decimal"},
        {"input": "water_pool_usd", "system": "qbd_132-700", "type": "currency_usd"},
        {"input": "phase_lot_count", "system": "clickup_phase_task", "type": "int"}
      ],
      "calculation": {
        "phase_share_usd": "water_pool_usd * (water_letter_units_phase / water_letter_units_total)",
        "per_lot_share_usd": "phase_share_usd / phase_lot_count"
      },
      "ratified": true,
      "verification_status": "inferred_from_briefing",
      "verification_note": "Briefing describes water allocating 'by letter' — interpreted as ratio of phase units to total units. Exact unit definition (acre-feet, taps, ERUs?) needs confirmation."
    },
    {
      "rule_id": "ALLOC-003",
      "method_id": "direct_per_phase",
      "name": "Direct Cost Allocation per Phase",
      "applies_to": {
        "cost_type": "Direct",
        "scope": "phase",
        "posting_account": "132-500",
        "alloc_pair": "132-500↔132-510"
      },
      "trigger_event": "ongoing",
      "trigger_event_secondary": ["lot_sale"],
      "inputs_required": [
        {"input": "direct_cost_pool_usd_phase", "system": "qbd_132-500_by_DIR_job", "type": "currency_usd"},
        {"input": "phase_lot_count", "system": "clickup_phase_task", "type": "int"}
      ],
      "calculation": {
        "per_lot_share_usd": "direct_cost_pool_usd_phase / phase_lot_count",
        "weighting_note": "Equal-weight per lot within phase per briefing. Lot-type cost differential (e.g., SFR vs TH foundation cost) is not modeled in v0.2."
      },
      "ratified": true,
      "verification_status": "source_doc_extracted"
    },
    {
      "rule_id": "ALLOC-004",
      "method_id": "indirect_community",
      "name": "Indirect Cost Allocation across Community by Sales Basis",
      "applies_to": {
        "cost_type": "Indirect",
        "scope": "community",
        "posting_account": "132-600",
        "alloc_pair": "132-600↔132-610"
      },
      "trigger_event": "ongoing",
      "trigger_event_secondary": ["lot_sale"],
      "inputs_required": [
        {"input": "indirect_pool_usd_community", "system": "qbd_132-600_by_IND_job", "type": "currency_usd"},
        {"input": "sales_basis_pct_per_phase", "system": "allocation_workbook_engine_sheet", "type": "decimal_pct", "fallback": "lot_count_pct_per_phase"},
        {"input": "lot_count_per_phase", "system": "clickup_phase_task", "type": "int", "fallback_for": "sales_basis_pct_per_phase"},
        {"input": "phase_lot_count", "system": "clickup_phase_task", "type": "int"}
      ],
      "calculation": {
        "phase_share_usd_primary": "indirect_pool_usd_community * sales_basis_pct_per_phase",
        "phase_share_usd_fallback": "indirect_pool_usd_community * (lot_count_per_phase / sum(lot_count_per_phase across community))",
        "per_lot_share_usd": "phase_share_usd / phase_lot_count"
      },
      "ratified": true,
      "verification_status": "inferred_from_briefing",
      "verification_note": "Briefing notes 'sales_basis_pct OR lot_count_pct' — sales basis is preferred per Flagship workbook v3 pattern. Open question: does the choice of weighting need to be ratified per community?"
    },
    {
      "rule_id": "ALLOC-005",
      "method_id": "warranty_at_sale",
      "name": "Warranty Accrual at Lot Sale",
      "applies_to": {
        "cost_type": "Warranty",
        "scope": "lot",
        "posting_account": "240-102",
        "alloc_pair": "240-102↔240-112"
      },
      "trigger_event": "lot_sale",
      "inputs_required": [
        {"input": "warranty_rate", "system": "process_rule_or_workbook", "type": "decimal_pct"},
        {"input": "transfer_value_usd", "system": "clickup", "type": "currency_usd", "field_for_sih": "FMV at Transfer", "field_for_3rdy": "Sale Price"}
      ],
      "calculation": {
        "warranty_accrual_usd": "transfer_value_usd * warranty_rate"
      },
      "ratified": true,
      "verification_status": "inferred_from_briefing",
      "verification_note": "Default warranty rate not given in briefing. Open question: is the rate global, per DevCo, or per community?"
    },
