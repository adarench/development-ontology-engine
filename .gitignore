# --- Generated bulk data ---
# Keep CSV/parquet/Excel out of the repo by default — they're regenerated by the pipeline.
*.csv
*.parquet
*.xls*
*.xlsx
*.xlsb

# --- Raw source extracts (large; live outside the repo) ---
DataRails_raw.zip
phase_cost_starter_data.zip
data/raw/
data/_unzip_tmp/
data/processed/

# --- Generated artifacts inside output/ ---
# `output/` is the build target. We exclude bulk artifacts but keep the small
# state deliverables (markdown contracts, structured JSON state files,
# rendered architecture HTML, agent chunks) tracked.
output/*.csv
output/*.parquet
output/operating_dashboard_v1.html
output/operating_state_console_v1.html

# --- Caches / OS junk ---
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.DS_Store
*.tsbuildinfo

# --- Secrets ---
.env
.env.*
!.env.example
*.pem
*.key

# Local bearer token for the hosted MCP server (Fly.io). Generated by
# `fly secrets set BCPD_MCP_TOKEN` and mirrored to disk so clients can
# `cat` it into their configs. Never commit.
.bcpd_mcp_token.local

# --- Hand-curated spec CSVs that ARE tracked (override the *.csv rule) ---
!docs/field_map_v0.csv
!tests/fixtures/*.csv
